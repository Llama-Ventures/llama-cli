{
  "name": "@llamaventures/cli",
  "version": "1.19.0",
  "description": "CLI + MCP server for the Llama Ventures investment workbench (command.llamaventures.vc).",
  "type": "module",
  "scripts": {
    "test": "npm run test:agent-routing && npm run test:retired-personas && npm run test:contract",
    "test:agent-routing": "node scripts/verify-agent-routing.mjs",
    "test:retired-personas": "node scripts/verify-retired-personas.mjs",
    "test:contract": "node --test scripts/build-manifest.test.mjs scripts/core-api-call-sites.test.mjs scripts/verify-core-api-contract.test.mjs && node scripts/verify-core-api-contract.mjs",
    "verify:artifact": "node scripts/verify-release-artifact.mjs",
    "verify:release": "npm test && npm run verify:artifact && node scripts/verify-tarball-clean.mjs",
    "prepack": "node scripts/prepare-build-manifest.mjs",
    "postpack": "node scripts/cleanup-build-manifest.mjs"
  },
  "bin": {
    "llama": "bin/llama.mjs",
    "llama-mcp": "bin/llama-mcp.mjs"
  },
  "files": [
    "bin/",
    "contracts/",
    "lib/",
    "AGENT_BRIEFING.md",
    "CHANGELOG.md",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://github.com/Llama-Ventures/llama-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Llama-Ventures/llama-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Llama-Ventures/llama-cli/issues"
  },
  "keywords": [
    "llama-ventures",
    "venture-capital",
    "investment-pipeline",
    "cli",
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "agent",
    "ai-agent",
    "anthropic"
  ],
  "author": "Llama Ventures, Inc.",
  "funding": "https://github.com/Llama-Ventures/llama-cli",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "zod": "^4.4.3"
  }
}
